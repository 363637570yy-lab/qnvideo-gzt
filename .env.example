AUTH_ENABLED=true
JWT_SECRET=change-this-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-first-login

PGHOST=host.docker.internal
PGPORT=5432
PGDATABASE=qnvideo_gzt
PGUSER=qnvideo_gzt
PGPASSWORD=change-me

STORAGE_BASE_URL=http://localhost:20880/static

# Optional proxy for AI provider access. Leave empty when not needed.
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1,::1,backend,qnvideo-gzt-backend,host.docker.internal,192.168.0.0/16,172.16.0.0/12,10.0.0.0/8
